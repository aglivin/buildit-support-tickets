# OpenAI API key for LLM-based ticket enrichment.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Async PostgreSQL connection string. Local default points at the
# postgres container exposed on host port 5433 by docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/buildit

# OpenAI model used for triage. gpt-4o-mini is the cheapest option
# that reliably uses function calling.
LLM_MODEL=gpt-4o-mini

# Hard timeout for the synchronous enrichment call (seconds). If the
# LLM doesn't respond within this window, the ticket is saved as
# `pending` and finished in a background task.
LLM_TIMEOUT_SECONDS=5.0

# Time window during which an identical ticket (same email + body) is
# treated as a duplicate and returns the existing record.
DEDUP_WINDOW_MINUTES=5
